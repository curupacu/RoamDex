rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    function isValidSave(data) {
      return data.keys().hasAll(['version', 'candies', 'lastSavedAt'])
        && data.version is int
        && data.version >= 0
        && data.candies is number
        && data.candies >= 0
        && data.lastSavedAt is number
        // reject timestamps "from the future" (5 min margin for clock skew)
        && data.lastSavedAt <= request.time.toMillis() + 300000;
    }

    // Main save — one document per player
    match /saves/{uid} {
      allow read: if isOwner(uid);
      allow create, update: if isOwner(uid) && isValidSave(request.resource.data);
      allow delete: if isOwner(uid);

      // Backup of the last 3 versions (anti-corruption history)
      match /backups/{backupId} {
        allow read: if isOwner(uid);
        allow create, update: if isOwner(uid) && isValidSave(request.resource.data);
        allow delete: if isOwner(uid);
      }
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
